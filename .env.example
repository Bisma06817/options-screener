# --- Tastytrade OAuth2 (run scripts/oauth_setup.py once to populate) ---
TASTYTRADE_CLIENT_SECRET=
TASTYTRADE_REFRESH_TOKEN=
TASTYTRADE_ACCOUNT_ID=

# --- Anthropic API (Claude agent that drives the screener) ---
ANTHROPIC_API_KEY=

# --- Google Sheets ---
# Single-line JSON contents of the service-account key file
GOOGLE_SERVICE_ACCOUNT_JSON=
# Spreadsheet ID — the long string between /d/ and /edit in the Sheet URL
SPREADSHEET_ID=
